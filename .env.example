# ── Telegram Scraper ──
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+994XXXXXXXXXX
TELEGRAM_SESSION_NAME=news_ingestor
TELEGRAM_SESSION_DIR=./state/telethon
TELEGRAM_BACKFILL_LIMIT=200
TELEGRAM_AUDIT_SIZE=10
TELEGRAM_REFRESH_SECONDS=30

# ── Shared Database ──
DATABASE_URL=postgresql+asyncpg://news_ingestor:news_ingestor@localhost:5433/news_ingestor

# ── Web Scraper ──
SONXEBER_PGHOST=127.0.0.1
SONXEBER_PGPORT=5433
SONXEBER_PGUSER=news_ingestor
SONXEBER_PGPASSWORD=news_ingestor
SONXEBER_PGDATABASE=news_ingestor
SONXEBER_PGADMIN_DATABASE=news_ingestor

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO
CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=8080
